# Copy this file to .env and adjust if needed. .env is gitignored -- it's
# your local configuration and should never be committed (especially once
# it contains real credentials).
#
# These values are used by:
#   - docker-compose.yml (to create the Postgres container/database)
#   - data/load_data.py (to connect and load data)
#   - (later) the app, to connect to the database

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sema_db
POSTGRES_USER=sema_user
POSTGRES_PASSWORD=sema_password

# Read-only role used by the SEMA agent's run_sql tool (see
# sql/create_readonly_role.sql). This login can only SELECT.
POSTGRES_READONLY_USER=sema_readonly
POSTGRES_READONLY_PASSWORD=sema_readonly_pw

# Claude API key for the agent. Leave blank until you have one -- the app
# will run and show "Claude API key is not configured yet." without it.
ANTHROPIC_API_KEY=
